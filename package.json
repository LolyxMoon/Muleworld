{
  "name": "mulerun-world",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:party": "npx partykit dev party/server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:party\"",
