    "preview": "vite preview",
    "deploy:party": "npx partykit deploy party/server.js --name mulerun-world"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "partykit": "^0.0.111",
    "concurrently": "^9.1.0",
    "vite": "^6.0.0"
  }
}
